class Volume {
    void calculateVolume(int side) {
        System.out.println("Cube: " + (side * side * side));
    }

    void calculateVolume(int l, int w, int h) {
        System.out.println("Cuboid: " + (l * w * h));
    }

    void calculateVolume(double r) {
        System.out.println("Sphere: " + (4.0/3 * Math.PI * r * r * r));
    }

    public static void main(String[] args) {
        Volume v = new Volume();
        v.calculateVolume(3);
        v.calculateVolume(2, 3, 4);
        v.calculateVolume(2.5);
    }
}